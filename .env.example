# Voon.fi Chatbot — Ympäristömuuttujat
# Kopioi tämä tiedosto nimellä .env (paikallinen kehitys)
# Vercel-tuotannossa: Dashboard → Settings → Environment Variables

# Google Gemini API avain (pakollinen)
# Luo: https://aistudio.google.com/apikey
GOOGLE_API_KEY=AIza...

# Gemini-malli (valinnainen, oletus: gemini-2.0-flash)
# Vaihtoehdot: gemini-2.0-flash | gemini-1.5-flash | gemini-1.5-pro
GEMINI_MODEL=gemini-2.0-flash
