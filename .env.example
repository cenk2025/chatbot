# Voon.fi Chatbot — Vercel Environment Variables
# Vercel Dashboard → Settings → Environment Variables

# OpenAI API anahtari (zorunlu)
# Luo: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# OpenAI modeli (valinnainen, oletus: gpt-4o-mini)
# Vaihtoehdot: gpt-4o-mini | gpt-4o | gpt-3.5-turbo
OPENAI_MODEL=gpt-4o-mini
